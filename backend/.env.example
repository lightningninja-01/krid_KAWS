# --- App ---
ENVIRONMENT=development
LOG_LEVEL=INFO
PORT=8000

# Comma-separated list of origins allowed to call this API (the frontend's URL)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- MongoDB Atlas ---
# Get this from Atlas -> Connect -> Drivers -> Python. Use an M0 free-tier cluster.
MONGODB_URI=mongodb+srv://krid_ai:SeMaX234@cluster0.xtsyuoe.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=krid_ai

# --- Gemini ---
GEMINI_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash

# --- Meta WhatsApp Cloud API ---
# App Secret: Meta App Dashboard -> App Settings -> Basic
META_APP_SECRET=your_meta_app_secret
# Any string you choose — must match what you enter in the Meta webhook config UI
META_WEBHOOK_VERIFY_TOKEN=choose_a_verify_token
# Meta App Dashboard -> WhatsApp -> API Setup -> Temporary/Permanent Access Token
META_ACCESS_TOKEN=your_meta_access_token
# Meta App Dashboard -> WhatsApp -> API Setup -> Phone Number ID
META_PHONE_NUMBER_ID=your_phone_number_id
META_GRAPH_API_VERSION=v20.0

# --- Typing indicator / handover tuning ---
TYPING_HEARTBEAT_INTERVAL_SECONDS=20
HANDOVER_SENTIMENT_THRESHOLD=0.75
